{
  "name": "qpcak",
  "version": "0.1.0",
  "description": "Backend-free semantic search for any site. Index content into a tiny TurboQuant-compressed pack and search it locally in the browser — no server, no per-query cost.",
  "type": "module",
  "bin": {
    "qpcak": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./build": {
      "types": "./dist/build.d.ts",
      "import": "./dist/build.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "qdrant",
    "vector-search",
    "semantic-search",
    "embeddings",
    "turboquant",
    "wasm",
    "browser",
    "offline",
    "rag",
    "quantization"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "tsx": "^4.22.3",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@qdrant/js-client-rest": "^1.18.0"
  }
}
